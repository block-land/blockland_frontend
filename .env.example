# Public canonical site URL, used for SEO metadata and JSON-LD.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Mapbox Access Token (https://account.mapbox.com)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_access_token_here

# Privy App ID (https://dashboard.privy.io)
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id_here

# Public backend URL. Set this to https://api.blockland.app before production build.
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# Blockland Solana
# Cluster: "devnet" | "mainnet-beta" (default: devnet)
